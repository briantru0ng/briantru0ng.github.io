---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  image?: string;
  tags?: string[];
  category: 'food' | 'art';
}

const { title, description, date, image, tags, category } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const categoryLabel = category === 'food' ? 'Food Blog' : 'Art Blog';
const backLink = `/blog/${category}`;
---

<BaseLayout title={title} description={description}>
  <article class="blog-post">
    <div class="container">
      <header class="post-header">
        <a href={backLink} class="back-link">← Back to {categoryLabel}</a>
        <span class="post-date">{formattedDate}</span>
        <h1 class="post-title">{title}</h1>
        {tags && tags.length > 0 && (
          <div class="post-tags">
            {tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </header>

      {image && (
        <div class="post-image-wrapper">
          <img src={image} alt={title} class="post-image" />
        </div>
      )}

      <div class="post-content prose">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding-bottom: var(--spacing-xl);
  }

  .post-header {
    padding: var(--spacing-lg) 0;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--spacing-lg);
  }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-md);
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .post-date {
    display: block;
    font-size: 0.75rem;
    color: var(--color-accent);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-xs);
  }

  .post-title {
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    margin-bottom: var(--spacing-sm);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
  }

  .post-image-wrapper {
    margin-bottom: var(--spacing-lg);
  }

  .post-image {
    width: 100%;
    max-height: 500px;
    object-fit: cover;
    border-radius: 8px;
  }

  .post-content {
    max-width: var(--content-width);
  }
</style>
