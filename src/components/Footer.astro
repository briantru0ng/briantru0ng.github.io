---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-content">
      <p class="footer-text">
        &copy; {currentYear} Brian Truong
      </p>
      <div class="footer-links">
        <a href="https://github.com/briantru0ng" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://linkedin.com/in/briantru0ng" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .footer-container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--spacing-md);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .footer-text {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0;
  }

  .footer-links {
    display: flex;
    gap: var(--spacing-md);
  }

  .footer-links a {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 480px) {
    .footer-content {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
