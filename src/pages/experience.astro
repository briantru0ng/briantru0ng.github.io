---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const experiences = await getCollection('experience', ({ data }) => data.shown);
const education = await getCollection('education', ({ data }) => data.shown);
const publications = await getCollection('publications', ({ data }) => data.shown);

// Filter out items with order === 0 (used for examples/hidden items)
// Then sort by order field, then by date (most recent first)
const sortedExperiences = experiences
  .filter(item => item.data.order !== 0)
  .sort((a, b) => {
    if (a.data.order != null && b.data.order != null) {
      return a.data.order - b.data.order;
    }
    return b.data.startDate.valueOf() - a.data.startDate.valueOf();
  });

// Split education into degrees and certifications
const sortedDegrees = education
  .filter(item => item.data.order !== 0 && item.data.type === 'degree')
  .sort((a, b) => {
    if (a.data.order != null && b.data.order != null) {
      return a.data.order - b.data.order;
    }
    return b.data.startDate.valueOf() - a.data.startDate.valueOf();
  });

const sortedCertifications = education
  .filter(item => item.data.order !== 0 && item.data.type === 'certification')
  .sort((a, b) => {
    if (a.data.order != null && b.data.order != null) {
      return a.data.order - b.data.order;
    }
    return b.data.startDate.valueOf() - a.data.startDate.valueOf();
  });

const sortedPublications = publications
  .filter(item => item.data.order !== 0)
  .sort((a, b) => {
    if (a.data.order != null && b.data.order != null) {
      return a.data.order - b.data.order;
    }
    return b.data.date.valueOf() - a.data.date.valueOf();
  });

// Helper to format date range (using UTC to prevent timezone offset issues)
function formatDateRange(startDate: Date, endDate?: Date) {
  const options: Intl.DateTimeFormatOptions = { month: 'short', year: 'numeric', timeZone: 'UTC' };
  const start = startDate.toLocaleDateString('en-US', options);

  // If no end date, show "Present"
  if (!endDate) {
    return `${start} - Present`;
  }

  const end = endDate.toLocaleDateString('en-US', options);

  // If start and end are the same, just show one date
  if (start === end) {
    return start;
  }

  return `${start} - ${end}`;
}

// Helper to format single date
function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric', timeZone: 'UTC' });
}
---

<BaseLayout title="Brian's Experience" description="Brian Truong's work experience">
  <div class="container">
    <header id="top" class="page-header">
      <h1 class="page-title">Experience</h1>
      <p class="page-description">My professional journey so far.</p>

      <nav class="section-tabs">
        <a href="#work" class="section-tab" data-section="work">Work Experience</a>
        <a href="#publications" class="section-tab" data-section="publications">Publications</a>
        <a href="#education" class="section-tab" data-section="education">Education</a>
        <a href="#certifications" class="section-tab" data-section="certifications">Certifications</a>
      </nav>
    </header>

    <!-- Work Experience Section -->
    <section id="work" class="experience-section">
      <h2 class="section-title">Work Experience</h2>
      <div class="timeline">
        {sortedExperiences.map(async (exp) => {
          const { Content } = await exp.render();
          return (
            <div class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <span class="timeline-period">{formatDateRange(exp.data.startDate, exp.data.endDate)}</span>
                <h3 class="timeline-role">{exp.data.role}</h3>
                <h4 class="timeline-company">
                  {exp.data.company}
                  {exp.data.location && <span class="timeline-location"> · {exp.data.location}</span>}
                </h4>

                {exp.data.tags && exp.data.tags.length > 0 && (
                  <div class="timeline-tags">
                    {exp.data.tags.map(tag => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}

                <div class="timeline-body">
                  <Content />
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Publications Section -->
    <section id="publications" class="experience-section">
      <h2 class="section-title">Publications</h2>
      <div class="timeline">
        {sortedPublications.map(async (pub) => {
          const { Content } = await pub.render();
          return (
            <div class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <span class="timeline-period">{formatDate(pub.data.date)}</span>
                <h3 class="timeline-role">{pub.data.title}</h3>
                <h4 class="timeline-company">
                  {pub.data.venue}
                  {pub.data.link && (
                    <a href={pub.data.link} class="pub-link" target="_blank" rel="noopener">
                      View Paper
                    </a>
                  )}
                </h4>

                {pub.data.authors && pub.data.authors.length > 0 && (
                  <p class="pub-authors">{pub.data.authors.join(', ')}</p>
                )}

                {pub.data.tags && pub.data.tags.length > 0 && (
                  <div class="timeline-tags">
                    {pub.data.tags.map(tag => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}

                <div class="timeline-body">
                  <Content />
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Education Section -->
    <section id="education" class="experience-section">
      <h2 class="section-title">Education</h2>
      <div class="timeline">
        {sortedDegrees.map(async (edu) => {
          const { Content } = await edu.render();
          return (
            <div class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <span class="timeline-period">{formatDateRange(edu.data.startDate, edu.data.endDate)}</span>
                {edu.data.type && <span class="timeline-type">{edu.data.type}</span>}
                <h3 class="timeline-role">{edu.data.degree}</h3>
                <h4 class="timeline-company">
                  {edu.data.institution}
                  {edu.data.location && <span class="timeline-location"> · {edu.data.location}</span>}
                </h4>

                {edu.data.tags && edu.data.tags.length > 0 && (
                  <div class="timeline-tags">
                    {edu.data.tags.map(tag => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}

                {edu.data.credentialLink && (
                  <a href={edu.data.credentialLink} class="credential-link" target="_blank" rel="noopener">
                    Show Credential
                  </a>
                )}

                <div class="timeline-body">
                  <Content />
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Certifications Section -->
    <section id="certifications" class="experience-section">
      <h2 class="section-title">Certifications</h2>
      <div class="timeline">
        {sortedCertifications.map(async (cert) => {
          const { Content } = await cert.render();
          return (
            <div class="timeline-item">
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <span class="timeline-period">{formatDateRange(cert.data.startDate, cert.data.endDate)}</span>
                {cert.data.type && <span class="timeline-type">{cert.data.type}</span>}
                <h3 class="timeline-role">{cert.data.degree}</h3>
                <h4 class="timeline-company">
                  {cert.data.institution}
                  {cert.data.location && <span class="timeline-location"> · {cert.data.location}</span>}
                </h4>

                {cert.data.tags && cert.data.tags.length > 0 && (
                  <div class="timeline-tags">
                    {cert.data.tags.map(tag => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}

                {cert.data.credentialLink && (
                  <a href={cert.data.credentialLink} class="credential-link" target="_blank" rel="noopener">
                    Show Credential
                  </a>
                )}

                <div class="timeline-body">
                  <Content />
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </section>
  </div>

  <!-- Back to Top Button -->
  <button id="back-to-top" class="back-to-top" aria-label="Back to top">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 15l-6-6-6 6"/>
    </svg>
  </button>
</BaseLayout>

<script>
  // Handle tab clicks - scroll directly to section
  document.querySelectorAll('.section-tab').forEach(tab => {
    tab.addEventListener('click', (e) => {
      e.preventDefault();
      const sectionId = tab.getAttribute('data-section');
      const section = document.getElementById(sectionId);

      if (section) {
        // Update active tab
        document.querySelectorAll('.section-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        // Update URL hash
        history.pushState(null, '', `#${sectionId}`);

        // Scroll to section
        section.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });

  // Set active tab based on current hash on load
  const hash = window.location.hash.slice(1);
  if (hash) {
    const activeTab = document.querySelector(`[data-section="${hash}"]`);
    if (activeTab) activeTab.classList.add('active');
  }

  // Back to top button
  const backToTop = document.getElementById('back-to-top');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 300) {
      backToTop?.classList.add('visible');
    } else {
      backToTop?.classList.remove('visible');
    }
  });

  backToTop?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
    // Clear active tab when going to top
    document.querySelectorAll('.section-tab').forEach(t => t.classList.remove('active'));
    history.pushState(null, '', window.location.pathname);
  });
</script>

<style>
  .section-tabs {
    display: flex;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-md);
    flex-wrap: wrap;
  }

  .section-tab {
    padding: var(--spacing-xs) var(--spacing-md);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .section-tab:hover,
  .section-tab.active {
    background: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }

  .experience-section {
    margin-bottom: var(--spacing-xl);
    scroll-margin-top: 80px;
  }

  .section-title {
    font-size: 1.5rem;
    color: var(--color-text);
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-sm);
    border-bottom: 2px solid var(--color-border);
  }

  .timeline {
    position: relative;
    padding-left: var(--spacing-lg);
    padding-bottom: var(--spacing-lg);
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-border);
  }

  .timeline-item {
    position: relative;
    padding-bottom: var(--spacing-lg);
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-marker {
    position: absolute;
    left: calc(-1 * var(--spacing-lg) - 5px);
    top: 6px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 2px solid var(--color-bg);
  }

  .timeline-content {
    background: var(--color-bg-elevated);
    padding: var(--spacing-md);
    border-radius: 8px;
    border: 1px solid var(--color-border);
  }

  .timeline-period {
    display: inline-block;
    font-size: 0.75rem;
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: var(--spacing-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .timeline-type {
    display: inline-block;
    font-size: 0.625rem;
    color: var(--color-bg);
    background: var(--color-accent);
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-left: var(--spacing-xs);
    vertical-align: middle;
  }

  .timeline-role {
    font-size: 1.25rem;
    color: var(--color-text);
    margin-bottom: 0;
  }

  .timeline-company {
    font-size: 1rem;
    color: var(--color-text-muted);
    font-weight: 400;
    margin-bottom: var(--spacing-sm);
  }

  .timeline-location {
    font-weight: 300;
  }

  .pub-link {
    margin-left: var(--spacing-sm);
    font-size: 0.75rem;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .pub-link:hover {
    text-decoration: underline;
  }

  .pub-authors {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: var(--spacing-sm);
  }

  .credential-link {
    display: inline-block;
    margin-bottom: var(--spacing-sm);
    font-size: 0.875rem;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .credential-link:hover {
    text-decoration: underline;
  }

  .timeline-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-sm);
  }

  .timeline-body {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  .timeline-body :global(h2) {
    font-size: 1rem;
    color: var(--color-text);
    margin-top: var(--spacing-sm);
    margin-bottom: var(--spacing-xs);
  }

  .timeline-body :global(p) {
    margin-bottom: var(--spacing-xs);
  }

  .timeline-body :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .timeline-body :global(li) {
    padding-left: 1.25rem;
    position: relative;
    margin-bottom: var(--spacing-xs);
  }

  .timeline-body :global(li)::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  .back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-accent);
    color: var(--color-bg);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transform: translateY(20px);
    transition: all 0.3s ease;
    z-index: 100;
  }

  .back-to-top.visible {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .back-to-top:hover {
    background: var(--color-accent-hover);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .timeline {
      padding-left: var(--spacing-md);
    }

    .timeline-marker {
      left: calc(-1 * var(--spacing-md) - 5px);
    }

    .back-to-top {
      bottom: 1rem;
      right: 1rem;
      width: 40px;
      height: 40px;
    }
  }
</style>
