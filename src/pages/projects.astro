---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects', ({ data }) => data.shown);

const sortedProjects = projects
  .filter(project => project.data.order !== 0)
  .sort((a, b) => {
    if (a.data.order != null && b.data.order != null) {
      return a.data.order - b.data.order;
    }
    return b.data.date.valueOf() - a.data.date.valueOf();
  });
---

<BaseLayout title="Brian's Projects" description="Brian Truong's projects and work">
  <div class="container">
    <header class="page-header">
      <h1 class="page-title">Projects</h1>
      <div class="page-subheader">
        <p class="page-description">Things I've built and worked on.</p>
        <div class="view-toggle">
          <button class="view-btn active" data-view="list" aria-label="List view">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
          </button>
          <button class="view-btn" data-view="grid" aria-label="Grid view">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <div class="projects-container list-view" id="projects-container">
      {sortedProjects.map(project => (
        <a href={`/projects/${project.slug}`} class="project-card">
          <div class="project-info">
            <h2 class="project-title">{project.data.title}</h2>
            <p class="project-description">{project.data.description}</p>
            {project.data.tags && project.data.tags.length > 0 && (
              <div class="project-tags">
                {project.data.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
          {project.data.image && (
            <div class="project-image-wrapper">
              <div class="project-image-fade"></div>
              <img
                src={project.data.image}
                alt={project.data.title}
                class="project-image"
                loading="lazy"
              />
            </div>
          )}
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-subheader {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .page-subheader .page-description {
    margin-bottom: 0;
  }

  .view-toggle {
    display: flex;
    gap: 4px;
  }

  .view-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px 8px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
    color: var(--color-text-muted);
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .view-btn:hover {
    color: var(--color-text);
  }

  .view-btn.active {
    background: var(--color-border);
    color: var(--color-text);
  }

  /* ── List View ── */
  .projects-container.list-view {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    padding-bottom: var(--spacing-xl);
  }

  .list-view .project-card {
    display: flex;
    align-items: stretch;
    background: var(--color-bg-elevated);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    text-decoration: none;
    height: 180px;
  }

  .list-view .project-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.3);
    border-color: var(--color-accent);
  }

  .list-view .project-info {
    flex: 1;
    padding: var(--spacing-sm) var(--spacing-md);
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
    z-index: 1;
  }

  .list-view .project-image-wrapper {
    position: relative;
    width: 280px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .list-view .project-image-fade {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 60px;
    background: linear-gradient(to right, var(--color-bg-elevated), transparent);
    z-index: 1;
  }

  .list-view .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .list-view .project-card:hover .project-image {
    transform: scale(1.05);
  }

  /* ── Grid View ── */
  .projects-container.grid-view {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--spacing-md);
    padding-bottom: var(--spacing-xl);
  }

  .grid-view .project-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg-elevated);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    text-decoration: none;
  }

  .grid-view .project-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.3);
    border-color: var(--color-accent);
  }

  .grid-view .project-info {
    padding: var(--spacing-sm);
    order: 2;
  }

  .grid-view .project-image-wrapper {
    position: relative;
    order: 1;
    overflow: hidden;
  }

  .grid-view .project-image-fade {
    display: none;
  }

  .grid-view .project-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .grid-view .project-card:hover .project-image {
    transform: scale(1.05);
  }

  /* ── Shared text ── */
  .project-title {
    font-size: 1.1rem;
    color: var(--color-text);
    margin-bottom: 4px;
  }

  .project-description {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-xs);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .project-tags .tag {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .list-view .project-card {
      flex-direction: column;
      height: auto;
    }

    .list-view .project-image-wrapper {
      width: 100%;
      height: 140px;
      order: -1;
    }

    .list-view .project-image-fade {
      display: none;
    }
  }
</style>

<script>
  const container = document.getElementById('projects-container');
  const buttons = document.querySelectorAll('.view-btn');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const view = btn.getAttribute('data-view');
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      container?.classList.remove('list-view', 'grid-view');
      container?.classList.add(`${view}-view`);
    });
  });
</script>
